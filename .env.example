# Copy to `.env.local` and fill from Supabase Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

# Project URL — must look like https://abcdefgh.supabase.co (NOT the publishable key URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# anon public key OR publishable key — paste into THIS variable only
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here

# After running supabase/migrations/20250521000003_profile_avatar_oauth.sql:
# VITE_PROFILES_AVATAR_COLUMN=true
